---
import Hero from '../components/Hero.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About | Morten Barthel" description="Morten Barthel">
	<div class="stack gap-20">
		<main class="wrapper about">
			<Hero
				title="About"
				tagline="Thanks for stopping by. Read below to learn more about me and my projects."
			>
                <div class="image-row">
                    <img
                        width="300"
                        height="200"
                        src="/assets/code_c.png"
                        alt="Code from Cnake"
                    />
                    <img
                        width="300"
                        height="200"
                        src="/assets/code_python.png"
                        alt="Code from MCpypack"
                    />
                </div>
			</Hero>

			<section>
				<h2 class="section-title">Background</h2>
				<div class="content">
                    <p>I was born in Bielefeld, Germany.</p>
                    <p>Currently I am 15 years old and enjoy coding in my free time.</p>
				</div>
			</section>
			<section>
				<h2 class="section-title">Education</h2>
                <div class="content">
                <p>I am currently attending a high school in Germany.</p>
                <p>In my free time, I am also a student in the <a href="https://www.uni-rostock.de/studium/studienorientierung/juniorstudium/">Juniorstudium program at the University of Rostock</a>.</p>
                </div>
			</section>
			<section>
				<h2 class="section-title">Skills</h2>
                <div class="content">
                <p>I am a self-taught programmer with a passion for building projects and solving problems.</p>
                <p>I have experience with Git and Linux, and I enjoy working in open-source environments.</p>
                </div>
			</section>
			<section>
				<h2 class="section-title">By the way</h2>
                <div class="content">
                    <p><b>I use Arch btw</b></p>
                </div>
			</section>
		</main>

	</div>
</BaseLayout>

<style>
	.about {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
	}

	img {
		margin-top: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: var(--shadow-md);
	}

	section {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		color: var(--gray-200);
	}

	.section-title {
		grid-column-start: 1;
		font-size: var(--text-xl);
		color: var(--gray-0);
	}

	.content {
		grid-column: 2 / 4;
	}

	.content :global(a) {
		text-decoration: 1px solid underline transparent;
		text-underline-offset: 0.25em;
		transition: text-decoration-color var(--theme-transition);
	}

	.content :global(a:hover),
	.content :global(a:focus) {
		text-decoration-color: currentColor;
	}

	@media (min-width: 50em) {
		.about {
			display: grid;
			grid-template-columns: 1fr 60% 1fr;
		}

		.about > :global(:first-child) {
			grid-column-start: 2;
		}

		section {
			display: contents;
			font-size: var(--text-lg);
		}
	}

    .image-row {
        display: flex;
        gap: 1.5rem; /* space between images */
        justify-content: center; /* center horizontally */
        flex-wrap: wrap; /* optional: wrap on small screens */
        }

    .image-row img {
        margin-top: 1.5rem; /* keep your previous spacing */
        border-radius: 1.5rem;
        box-shadow: var(--shadow-md);
        }
</style>
